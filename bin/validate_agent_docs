#!/usr/bin/env bash
# Usage: bin/validate_agent_docs <file> [<file> ...]
errors=()
for file in "$@"; do
  non_empty=$(grep -cv '^[[:space:]]*$' "$file" 2>/dev/null || echo 0)
  [ "$non_empty" -gt 50 ] && errors+=("$file: $non_empty non-empty lines (max 50)")
  line_num=0
  while IFS= read -r line || [ -n "$line" ]; do
    line_num=$((line_num + 1))
    len=${#line}
    [ "$len" -gt 99 ] && errors+=("$file:$line_num: $len chars (max 99)")
  done < "$file"
done
if [ "${#errors[@]}" -gt 0 ]; then
  echo "Validation errors:" >&2
  for e in "${errors[@]}"; do echo "  - $e" >&2; done
  exit 1
fi
echo "OK"
